{
  "name": "codewithagents",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "lint:eslint": "eslint .",
    "lint:all": "pnpm lint && pnpm lint:eslint && pnpm format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "pnpm --filter @codewithagents/examples run smoke",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:watch": "fallow watch"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "fallow": "^2.85.0",
    "prettier": "catalog:",
    "typescript": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "qs": "^6.15.2"
    }
  }
}
