{
  "name": "codewithagents",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test && pnpm fallow:audit",
    "lint": "pnpm -r run lint",
    "smoke": "pnpm --filter @codewithagents/examples run smoke",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:watch": "fallow watch"
  },
  "devDependencies": {
    "fallow": "^2.84.0",
    "typescript": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "qs": "^6.15.2"
    }
  }
}
