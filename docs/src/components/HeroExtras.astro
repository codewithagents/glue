---
// HeroExtras - install snippet, proof stat, and shield row.
// Inline styles use Starlight CSS variables so the component is theme-aware.
// No third-party images or logos; shields use static shields.io URLs.
---

<div class="hero-extras">
  <div class="install-block" aria-label="Install command">
    <span class="install-label">Install</span>
    <code class="install-cmd">npm install -D @codewithagents/openapi-gen</code>
    <button
      class="copy-btn"
      aria-label="Copy install command"
      data-copy="npm install -D @codewithagents/openapi-gen"
    >
      <svg
        class="copy-icon"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3" />
        <path
          d="M3 11V3a1 1 0 0 1 1-1h8"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
        />
      </svg>
      <span class="copy-feedback" aria-live="polite"></span>
    </button>
  </div>

  <p class="proof-stat">
    Tested against <strong>128 real-world specs</strong> (Stripe, GitHub, Spotify, OpenAI) in CI on
    every commit.
  </p>

  <div class="shield-row" aria-label="Package badges">
    <a
      href="https://www.npmjs.com/package/@codewithagents/openapi-gen"
      target="_blank"
      rel="noopener noreferrer"
      class="shield-link"
      aria-label="openapi-gen on npm"
    >
      <img
        src="https://img.shields.io/npm/v/@codewithagents/openapi-gen?label=openapi-gen&color=10b981&style=flat-square"
        alt="openapi-gen npm version"
        loading="lazy"
        width="140"
        height="20"
      />
    </a>
    <a
      href="https://www.npmjs.com/package/@codewithagents/openapi-react-query"
      target="_blank"
      rel="noopener noreferrer"
      class="shield-link"
      aria-label="openapi-react-query on npm"
    >
      <img
        src="https://img.shields.io/npm/v/@codewithagents/openapi-react-query?label=openapi-react-query&color=10b981&style=flat-square"
        alt="openapi-react-query npm version"
        loading="lazy"
        width="185"
        height="20"
      />
    </a>
    <a
      href="https://github.com/codewithagents/openapi-ts/blob/main/LICENSE"
      target="_blank"
      rel="noopener noreferrer"
      class="shield-link"
      aria-label="License: MIT"
    >
      <img
        src="https://img.shields.io/badge/license-MIT-10b981?style=flat-square"
        alt="MIT license"
        loading="lazy"
        width="85"
        height="20"
      />
    </a>
  </div>
</div>

<script>
  // Minimal copy-to-clipboard for the install command.
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? ''
      try {
        await navigator.clipboard.writeText(text)
        const fb = btn.querySelector<HTMLElement>('.copy-feedback')
        if (fb) {
          fb.textContent = 'Copied!'
          setTimeout(() => {
            fb.textContent = ''
          }, 2000)
        }
        btn.setAttribute('aria-pressed', 'true')
        setTimeout(() => btn.setAttribute('aria-pressed', 'false'), 2000)
      } catch {
        // Clipboard not available; silently ignore.
      }
    })
  })
</script>

<style>
  .hero-extras {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0 0.5rem;
  }

  /* Install command block */
  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background: var(--sl-color-gray-7);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-sm);
  }

  .install-label {
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
    font-family: var(--sl-font);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .install-cmd {
    color: var(--sl-color-accent-high);
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: inherit;
    white-space: nowrap;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    padding: 0.2rem 0.4rem;
    cursor: pointer;
    color: var(--sl-color-gray-2);
    transition: color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .copy-icon {
    width: 14px;
    height: 14px;
  }

  .copy-feedback {
    font-size: 0.7rem;
    min-width: 3ch;
    font-family: var(--sl-font);
    color: var(--sl-color-accent);
  }

  /* Proof stat */
  .proof-stat {
    margin: 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    text-align: center;
  }

  .proof-stat strong {
    color: var(--sl-color-white);
  }

  /* Shields row */
  .shield-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
  }

  .shield-link {
    display: inline-flex;
    align-items: center;
    border: none;
  }

  .shield-link img {
    height: 20px;
    width: auto;
    border-radius: 3px;
  }

  @media (max-width: 480px) {
    .install-cmd {
      font-size: 0.78rem;
    }
    .install-block {
      flex-wrap: wrap;
    }
  }
</style>
