---
// PipelineDiagram — visual representation of the Glue package pipeline.
// Uses Starlight CSS variables throughout so it renders correctly in both
// light and dark themes. Layout is responsive: horizontal on wide screens,
// stacked vertically on narrow screens.
---

<div class="pipeline-root" role="img" aria-label="Glue pipeline: OpenAPI spec feeds openapi-gen, which produces TypeScript types, Zod schemas, and a fetch client. The fetch client feeds openapi-react-query for React Query hooks and openapi-server for a typed service interface and router. api-errors maps any API error shape to form fields independently.">

  <!-- Row 1: Source -->
  <div class="pipeline-row">
    <div class="pipeline-box pipeline-box--source">
      <span class="pipeline-label-small">your</span>
      <span class="pipeline-label">OpenAPI spec</span>
    </div>
  </div>

  <!-- Arrow down -->
  <div class="pipeline-row pipeline-row--arrow">
    <div class="pipeline-arrow pipeline-arrow--down">↓</div>
  </div>

  <!-- Row 2: openapi-gen -->
  <div class="pipeline-row">
    <div class="pipeline-box pipeline-box--generator">
      <span class="pipeline-pkg">@codewithagents/openapi-gen</span>
    </div>
  </div>

  <!-- Arrow down + fan out -->
  <div class="pipeline-row pipeline-row--arrow">
    <div class="pipeline-arrow pipeline-arrow--down">↓</div>
  </div>

  <!-- Row 3: three outputs of openapi-gen -->
  <div class="pipeline-row pipeline-row--outputs">
    <div class="pipeline-box pipeline-box--output">
      <span class="pipeline-label">TypeScript types</span>
      <span class="pipeline-label-small">models.ts</span>
    </div>
    <div class="pipeline-box pipeline-box--output">
      <span class="pipeline-label">Zod schemas</span>
      <span class="pipeline-label-small">schemas.ts (yours to extend)</span>
    </div>
    <div class="pipeline-box pipeline-box--output pipeline-box--output-key">
      <span class="pipeline-label">Fetch client</span>
      <span class="pipeline-label-small">client.ts</span>
    </div>
  </div>

  <!-- Arrow down from fetch client -->
  <div class="pipeline-row pipeline-row--arrow">
    <div class="pipeline-arrow pipeline-arrow--down">↓</div>
  </div>

  <!-- Row 4: consumers of the fetch client -->
  <div class="pipeline-row pipeline-row--consumers">
    <div class="pipeline-box pipeline-box--consumer">
      <span class="pipeline-pkg">@codewithagents/openapi-react-query</span>
      <span class="pipeline-label-small">React Query v5 hooks</span>
    </div>
    <div class="pipeline-box pipeline-box--consumer">
      <span class="pipeline-pkg">@codewithagents/openapi-server</span>
      <span class="pipeline-label-small">Typed service interface + router</span>
    </div>
  </div>

  <!-- Standalone section: api-errors -->
  <div class="pipeline-row pipeline-row--standalone">
    <div class="pipeline-standalone-divider" aria-hidden="true"></div>
    <div class="pipeline-box pipeline-box--standalone">
      <span class="pipeline-pkg">@codewithagents/api-errors</span>
      <span class="pipeline-label-small">Runtime only, no codegen. Maps any API error shape to form field errors.</span>
    </div>
  </div>

</div>

<style>
  .pipeline-root {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 1.5rem 1rem;
    font-family: var(--sl-font);
  }

  /* ---- Rows ---- */
  .pipeline-row {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 720px;
  }

  .pipeline-row--arrow {
    height: 2rem;
    align-items: center;
  }

  .pipeline-row--outputs {
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .pipeline-row--consumers {
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .pipeline-row--standalone {
    flex-direction: column;
    align-items: center;
    margin-top: 1.5rem;
    width: 100%;
    max-width: 720px;
  }

  /* ---- Arrows ---- */
  .pipeline-arrow {
    font-size: 1.5rem;
    color: var(--sl-color-accent);
    line-height: 1;
  }

  /* ---- Boxes ---- */
  .pipeline-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    padding: 0.6rem 1rem;
    border-radius: 6px;
    border: 1.5px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-gray-7);
    text-align: center;
  }

  .pipeline-box--source {
    min-width: 160px;
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-accent-low);
  }

  .pipeline-box--generator {
    min-width: 260px;
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-accent-low);
  }

  .pipeline-box--output {
    flex: 1 1 160px;
    max-width: 220px;
    border-color: var(--sl-color-gray-4);
  }

  /* The "fetch client" box is the one that feeds downstream packages. */
  .pipeline-box--output-key {
    border-color: var(--sl-color-accent);
  }

  .pipeline-box--consumer {
    flex: 1 1 200px;
    max-width: 300px;
    border-color: var(--sl-color-gray-4);
  }

  .pipeline-box--standalone {
    max-width: 460px;
    width: 100%;
    border-color: var(--sl-color-gray-4);
    border-style: dashed;
  }

  /* ---- Typography ---- */
  .pipeline-label {
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-white);
    line-height: 1.3;
  }

  .pipeline-label-small {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    line-height: 1.3;
  }

  .pipeline-pkg {
    font-size: var(--sl-text-xs);
    font-family: var(--sl-font-mono);
    font-weight: 600;
    color: var(--sl-color-accent-high);
    line-height: 1.4;
  }

  /* ---- Standalone divider ---- */
  .pipeline-standalone-divider {
    width: 100%;
    max-width: 460px;
    height: 1px;
    background-color: var(--sl-color-gray-5);
    margin-bottom: 1rem;
  }

  /* ---- Responsive: stack outputs/consumers vertically on narrow screens ---- */
  @media (max-width: 480px) {
    .pipeline-row--outputs,
    .pipeline-row--consumers {
      flex-direction: column;
      align-items: center;
    }

    .pipeline-box--output,
    .pipeline-box--consumer {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
