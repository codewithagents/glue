{
  "name": "@codewithagents/openapi-react-query",
  "version": "3.1.0",
  "description": "Generate typed React Query v5 hooks from OpenAPI 3.1 specs",
  "type": "module",
  "bin": {
    "openapi-react-query": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "lint": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@codewithagents/openapi-gen": "workspace:*",
    "openapi-types": "^12.1.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codewithagents/glue"
  },
  "publishConfig": {
    "access": "public"
  }
}
