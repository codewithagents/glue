{
  "openapi": "3.1.0",
  "info": { "title": "Advanced Types API", "version": "1.0.0" },
  "paths": {},
  "components": {
    "schemas": {
      "Priority": {
        "type": "integer",
        "enum": [0, 1, 2]
      },
      "Score": {
        "type": "number",
        "enum": [0.5, 1.0, 1.5]
      },
      "MixedStatus": {
        "enum": ["active", 0, null]
      },
      "Circle": {
        "type": "object",
        "required": ["kind", "radius"],
        "properties": {
          "kind": { "type": "string" },
          "radius": { "type": "number" }
        }
      },
      "Rectangle": {
        "type": "object",
        "required": ["kind", "width", "height"],
        "properties": {
          "kind": { "type": "string" },
          "width": { "type": "number" },
          "height": { "type": "number" }
        }
      },
      "Triangle": {
        "type": "object",
        "required": ["kind", "base", "height"],
        "properties": {
          "kind": { "type": "string" },
          "base": { "type": "number" },
          "height": { "type": "number" }
        }
      },
      "Shape": {
        "oneOf": [
          { "$ref": "#/components/schemas/Circle" },
          { "$ref": "#/components/schemas/Rectangle" },
          { "$ref": "#/components/schemas/Triangle" }
        ],
        "discriminator": {
          "propertyName": "kind",
          "mapping": {
            "circle": "#/components/schemas/Circle",
            "rectangle": "#/components/schemas/Rectangle",
            "triangle": "#/components/schemas/Triangle"
          }
        }
      },
      "Animal": {
        "anyOf": [
          { "$ref": "#/components/schemas/Circle" },
          { "$ref": "#/components/schemas/Rectangle" }
        ],
        "discriminator": {
          "propertyName": "type"
        }
      },
      "Event": {
        "type": "object",
        "required": ["id", "createdAt"],
        "properties": {
          "id": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "startDate": { "type": "string", "format": "date" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
