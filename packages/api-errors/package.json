{
  "name": "@codewithagents/api-errors",
  "version": "0.5.0",
  "description": "Map backend API errors to form field errors. Framework-agnostic core with React Hook Form adapter.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "api",
    "errors",
    "form",
    "react-hook-form",
    "validation",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codewithagents/glue"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
