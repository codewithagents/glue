{
  "name": "@codewithagents/api-errors",
  "version": "1.0.4",
  "description": "Map backend API errors to form field errors. Framework-agnostic core with React Hook Form adapter.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "api-errors",
    "form-errors",
    "react-hook-form",
    "validation",
    "typescript",
    "error-mapping",
    "zod",
    "field-errors"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codewithagents/openapi-ts"
  },
  "homepage": "https://openapi.codewithagents.de/api-errors",
  "bugs": {
    "url": "https://github.com/codewithagents/openapi-ts/issues"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
